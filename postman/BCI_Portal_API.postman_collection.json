{
	"info": {
		"name": "BCI Portal API — Stage 1",
		"description": "Auth endpoints for BCI Portal.\n\nFolder 1 'Auth Flow' runs fully automated — no manual steps.\nFolder 2 'Authenticated Flow' requires a verified email (manual step).\n\nMake sure backend is running: php artisan serve --port=8001",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8001", "type": "string" },
		{ "key": "api_url", "value": "http://localhost:8001/api/v1", "type": "string" },
		{ "key": "xsrf_token", "value": "", "type": "string" },
		{ "key": "test_cnic", "value": "", "type": "string" },
		{ "key": "test_email", "value": "", "type": "string" },
		{ "key": "test_name", "value": "", "type": "string" },
		{ "key": "test_mobile", "value": "", "type": "string" },
		{ "key": "verified_cnic", "value": "", "type": "string" },
		{ "key": "verified_password", "value": "", "type": "string" }
	],
	"item": [
		{
			"name": "Auth Flow (Automated — Run in Order)",
			"item": [
				{
					"name": "1. Get CSRF Cookie",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var token = null;",
									"pm.response.headers.each(function(header) {",
									"    if (header.key === 'Set-Cookie' || header.key === 'set-cookie') {",
									"        var match = header.value.match(/XSRF-TOKEN=([^;]+)/);",
									"        if (match) token = decodeURIComponent(match[1]);",
									"    }",
									"});",
									"if (token) pm.collectionVariables.set('xsrf_token', token);",
									"",
									"pm.test('CSRF cookie received', function () {",
									"    pm.expect(token).to.not.be.null;",
									"    pm.expect(token.length).to.be.greaterThan(10);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Origin", "value": "http://localhost:3000" },
							{ "key": "Referer", "value": "http://localhost:3000/" }
						],
						"url": {
							"raw": "{{base_url}}/sanctum/csrf-cookie",
							"host": ["{{base_url}}"],
							"path": ["sanctum", "csrf-cookie"]
						}
					}
				},
				{
					"name": "2. Register — Success",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"var timestamp = Date.now();",
									"var cnicNum = String(timestamp).slice(-13).padStart(13, '3');",
									"var cnic = cnicNum.slice(0,5) + '-' + cnicNum.slice(5,12) + '-' + cnicNum.slice(12,13);",
									"var mobile = '03' + String(timestamp).slice(-9);",
									"pm.collectionVariables.set('test_cnic', cnic);",
									"pm.collectionVariables.set('test_email', 'student' + timestamp + '@test.com');",
									"pm.collectionVariables.set('test_name', 'Test Student');",
									"pm.collectionVariables.set('test_mobile', mobile);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.response.headers.each(function(header) {",
									"    if (header.key === 'Set-Cookie' || header.key === 'set-cookie') {",
									"        var match = header.value.match(/XSRF-TOKEN=([^;]+)/);",
									"        if (match) pm.collectionVariables.set('xsrf_token', decodeURIComponent(match[1]));",
									"    }",
									"});",
									"",
									"var res = pm.response.json();",
									"",
									"pm.test('Status is 201 Created', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('success is true', function () {",
									"    pm.expect(res.success).to.eql(true);",
									"});",
									"",
									"pm.test('Has user data with all fields', function () {",
									"    pm.expect(res.data.user).to.have.property('id');",
									"    pm.expect(res.data.user).to.have.property('name');",
									"    pm.expect(res.data.user).to.have.property('email');",
									"    pm.expect(res.data.user).to.have.property('cnic');",
									"    pm.expect(res.data.user).to.have.property('mobile');",
									"    pm.expect(res.data.user).to.have.property('nationality');",
									"    pm.expect(res.data.user.role).to.eql('student');",
									"    pm.expect(res.data.user.nationality).to.eql('pakistani');",
									"});",
									"",
									"pm.test('Has request_id', function () {",
									"    pm.expect(res.request_id).to.be.a('string');",
									"});",
									"",
									"pm.test('Message mentions verification', function () {",
									"    pm.expect(res.message.toLowerCase()).to.include('verif');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "X-XSRF-TOKEN", "value": "{{xsrf_token}}" },
							{ "key": "Origin", "value": "http://localhost:3000" },
							{ "key": "Referer", "value": "http://localhost:3000/" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"{{test_name}}\",\n    \"email\": \"{{test_email}}\",\n    \"cnic\": \"{{test_cnic}}\",\n    \"mobile\": \"{{test_mobile}}\",\n    \"nationality\": \"pakistani\",\n    \"password\": \"Password123!\",\n    \"password_confirmation\": \"Password123!\"\n}"
						},
						"url": {
							"raw": "{{api_url}}/register",
							"host": ["{{api_url}}"],
							"path": ["register"]
						}
					}
				},
